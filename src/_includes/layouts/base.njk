<!DOCTYPE html>
<html lang="en" data-theme="bark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title and title != "Home" %}{{ title }} | {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}" />
  {% if site.favicon %}
    <link rel="icon" href="{{ site.favicon }}" />
  {% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lato:wght@400;500&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="{{ '/assets/css/main.css' | url }}" />
</head>
<body>
  {% include "partials/header.njk" %}
  <main id="main-content">
    {{ content | safe }}
  </main>
  {% include "partials/footer.njk" %}
</body>
</html>
